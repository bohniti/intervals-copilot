# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://journal:journal@postgres:5432/journal

# ─── LLM (Nvidia NIM / Kimi K2.5) ────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=moonshotai/kimi-k2.5
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── intervals.icu (Garmin sync) ──────────────────────────────────────────────
# Find your athlete ID in your intervals.icu profile URL: intervals.icu/athlete/i12345/...
INTERVALS_ICU_ATHLETE_ID=i12345
# Generate an API key at: intervals.icu → Settings → API
INTERVALS_ICU_API_KEY=your-intervals-api-key

# ─── Brave Search (route validation) ─────────────────────────────────────────
# Get a free key at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=your-brave-api-key

# ─── App ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=false

# ─── Production only ──────────────────────────────────────────────────────────
DOMAIN=your-domain.com
POSTGRES_PASSWORD=change-me-in-prod
GITHUB_REPOSITORY=your-github-username/climbers-journal
